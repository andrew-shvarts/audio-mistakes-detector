# Flask
SECRET_KEY=change-me-in-production
MAX_CONTENT_LENGTH_MB=200

# Redis / Celery (docker-compose overrides REDIS_URL to the redis service)
REDIS_URL=redis://localhost:6379/0
JOB_TTL_SECONDS=86400

# Whisper transcription
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Rate limiting (flask-limiter syntax)
RATE_LIMIT=20 per minute

# Error-detection tunables (all optional, sensible defaults apply)
DETECTION_SILENCE_THRESHOLD=0.02
DETECTION_OVERLAPPING_THRESHOLD=2.0
DETECTION_CONFIDENCE_THRESHOLD=1.0
DETECTION_TOKEN_SIMILARITY_RATIO_THRESHOLD=80
DETECTION_MODEL_TYPE=medium
